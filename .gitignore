# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# credentials / sensitive
_credentials_DO_NOT_COMMIT.txt
*credentials*.txt
*credentials*.md
*secrets*.json
*secrets*.txt

# editor / OS
.idea/
.vscode/
Thumbs.db

# logs
*.log

# original asset sources (large, kept locally only)
/assets-source/

# design intake (zip + extracted preview, kept locally only)
/_design_inbox/
*.zip
