# ============================================================
# 穴党参謀AI フロントエンド — 環境変数テンプレート
# このファイルは公開可。実値は .env.local に記述する。
# ============================================================

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role-key...

# ---- LINE 公式アカウント (Messaging API) ----
LINE_OFFICIAL_ACCOUNT_ID=@your_account_id
LINE_CHANNEL_SECRET=your_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token

# ---- LINE Login ----
LINE_LOGIN_CHANNEL_ID=your_login_channel_id
LINE_LOGIN_CHANNEL_SECRET=your_login_channel_secret
LINE_LOGIN_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ---- Backend Predictions API ----
PREDICTIONS_API_BASE=http://internal-api.example
PREDICTIONS_API_TOKEN=

# ---- Session / Auth ----
AUTH_SESSION_SECRET=GENERATE_WITH_openssl_rand_base64_32

# ---- アプリ設定 ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BRAND_NAME=穴党参謀AI
